// Prisma schema for CIMS Campus LMS — see plan doc for design rationale.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- ENUMS ----------

enum Role {
  SUPER_ADMIN
  CAMPUS_ADMIN
  ACADEMIC_DIRECTOR
  PROGRAM_COORDINATOR
  LECTURER
  FINANCE
  MARKETING_OFFICER
  EXAMINATION_UNIT
  LIBRARY_OFFICER
  HR_OFFICER
  STUDENT
}

enum ContentType {
  FILE
  LINK
  VIDEO
  ZOOM
  GOOGLE_MEET
  RICH_TEXT
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum AnnouncementScope {
  INSTITUTION
  MODULE
}

enum RegistrationStatus {
  PAYMENT_PENDING
  PENDING
  APPROVED
  REJECTED
}

enum PaymentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentMethod {
  BANK_TRANSFER
  GATEWAY
}

enum SemesterStatus {
  UPCOMING
  ACTIVE
  CLOSED
}

enum CalendarEventType {
  SEMESTER_START
  SEMESTER_END
  EXAM_PERIOD
  HOLIDAY
  DEADLINE
  OTHER
}

enum EnrollmentStatus {
  ACTIVE
  WITHDRAWN
  COMPLETED
}

enum NotificationStatus {
  SENT
  FAILED
  STUBBED
}

enum QuizKind {
  QUIZ
  EXAM
}

// QUIZ: DRAFT -> PUBLISHED -> CLOSED (lecturer-controlled, like ContentStatus).
// EXAM: DRAFT -> SCHEDULED -> CLOSED (SCHEDULED only reachable via the Examination
// Unit's scheduleExam action; submittedForSchedulingAt marks a DRAFT exam as ready
// for their review queue).
enum QuizStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  CLOSED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  ESSAY
}

// ---------- CORE ----------

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String? // null for OAuth-only accounts (e.g. Google sign-in)
  firstName    String
  lastName     String
  phone        String?
  role         Role
  isActive     Boolean @default(true)

  // Only meaningful for STUDENT role: home program for catalog default / dashboard.
  // SetNull rather than Cascade: deleting a Program should not delete student accounts.
  programId String?
  program   Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lecturerAssignments       LecturerModuleAssignment[] @relation("LecturerAssignments")
  assignmentsGranted        LecturerModuleAssignment[] @relation("AssignedBy")
  registrations             SemesterRegistration[]     @relation("StudentRegistrations")
  decisionsGiven            SemesterRegistration[]     @relation("DecidedBy")
  enrollments               Enrollment[]
  announcementsAuthored     Announcement[]
  paymentsVerified          PaymentRecord[]            @relation("PaymentVerifiedBy")
  passwordResetTokens       PasswordResetToken[]
  calendarEventsCreated     CalendarEvent[]
  contentItemsCreated       ContentItem[]
  submissions               Submission[]               @relation("StudentSubmissions")
  submissionsGraded         Submission[]               @relation("SubmissionGradedBy")
  discussionThreadsAuthored DiscussionThread[]
  discussionPostsAuthored   DiscussionPost[]
  quizzesCreated            Quiz[]                     @relation("QuizCreatedBy")
  quizzesScheduled          Quiz[]                     @relation("QuizScheduledBy")
  quizAttempts              QuizAttempt[]              @relation("QuizAttemptStudent")

  @@index([role])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ---------- ACADEMIC STRUCTURE ----------

model Program {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?
  durationYears Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  modules        Module[]
  students       User[]
  curriculumFees ProgramCurriculumFee[]
}

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "2025/2026"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false) // only one should be active; enforced in academic-year.actions.ts
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  semesters Semester[]
  modules   Module[]
}

// A program's fee for a given curriculum position (e.g. "Year 1, Semester 1"). Keyed by
// yearLevel + semesterNumber rather than a specific Semester row, because the fee for
// "Year 1 Semester 1" is a property of the program's curriculum, not of any one academic
// year's calendar instance — it doesn't need re-entering every time a new academic year's
// Semester 1 is created, and it varies both across programs and across years of the same program.
model ProgramCurriculumFee {
  id             String   @id @default(cuid())
  programId      String
  program        Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  yearLevel      Int
  semesterNumber Int
  amount         Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([programId, yearLevel, semesterNumber])
}

model Semester {
  id                   String         @id @default(cuid())
  academicYearId       String
  academicYear         AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name                 String // "Semester 1"
  semesterNumber       Int // 1, 2 (or 3 for trimester systems)
  startDate            DateTime
  endDate              DateTime
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?
  // Fee lives on ProgramCurriculumFee (programId + yearLevel + semesterNumber), not here —
  // see that model's comment for why.
  status               SemesterStatus @default(UPCOMING)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  modules        Module[]
  registrations  SemesterRegistration[]
  calendarEvents CalendarEvent[]

  @@unique([academicYearId, semesterNumber])
}

model Module {
  id          String  @id @default(cuid())
  code        String // e.g. "CS101" — unique per offering, not globally
  title       String
  description String?
  credits     Int?
  yearLevel   Int // curriculum year of study within the program (1,2,3,4)
  capacity    Int?
  isActive    Boolean @default(true)

  programId      String
  program        Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  semesterId     String
  semester       Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weeks               ModuleWeek[]
  lecturerAssignments LecturerModuleAssignment[]
  announcements       Announcement[]
  enrollments         Enrollment[]
  registrationModules RegistrationModule[]
  discussionThreads   DiscussionThread[]
  quizzes             Quiz[]

  @@unique([code, academicYearId, semesterId])
  @@index([programId])
  @@index([academicYearId, semesterId])
}

model LecturerModuleAssignment {
  id           String   @id @default(cuid())
  lecturerId   String
  lecturer     User     @relation("LecturerAssignments", fields: [lecturerId], references: [id])
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  assignedById String?
  assignedBy   User?    @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedAt   DateTime @default(now())

  @@unique([lecturerId, moduleId])
}

// ---------- WEEKLY CONTENT ----------

model ModuleWeek {
  id          String   @id @default(cuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  weekNumber  Int
  title       String? // e.g. "Week 1: Introduction"
  description String?
  orderIndex  Int // supports drag-reorder independent of weekNumber
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contentItems ContentItem[]

  @@unique([moduleId, weekNumber])
}

model ContentItem {
  id          String        @id @default(cuid())
  weekId      String
  week        ModuleWeek    @relation(fields: [weekId], references: [id], onDelete: Cascade)
  type        ContentType
  title       String
  description String?
  status      ContentStatus @default(DRAFT)
  orderIndex  Int
  publishedAt DateTime?

  // type-specific, nullable fields (single-table, pragmatic for Phase 1)
  fileUrl       String?
  fileName      String?
  fileSizeBytes Int?
  mimeType      String?
  linkUrl       String?
  videoUrl      String?
  zoomJoinUrl   String?
  zoomMeetingId String?
  zoomPasscode  String?
  meetJoinUrl   String?
  richTextHtml  String? @db.Text

  // assignment fields — dueDate/isAssignment orthogonal to type; grading lives on Submission
  isAssignment Boolean   @default(false)
  dueDate      DateTime?

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Submission[]

  @@index([weekId, status])
}

model Submission {
  id            String      @id @default(cuid())
  contentItemId String
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  studentId     String
  student       User        @relation("StudentSubmissions", fields: [studentId], references: [id])
  textResponse  String?     @db.Text
  fileUrl       String?
  submittedAt   DateTime    @default(now())
  grade         Decimal?    @db.Decimal(5, 2)
  feedback      String?
  gradedAt      DateTime?
  gradedById    String?
  gradedBy      User?       @relation("SubmissionGradedBy", fields: [gradedById], references: [id], onDelete: SetNull)
  updatedAt     DateTime    @updatedAt

  @@unique([contentItemId, studentId])
}

// ---------- ASSESSMENT (QUIZZES & EXAMS) ----------
// QUIZ: authored and published directly by the owning lecturer, like an assignment.
// EXAM: lecturer drafts the questions then submits for scheduling; an Examination Unit
// staff member sets the availability window and publishes it (scheduleExam). Both kinds
// share one model since the question/attempt/grading machinery is identical — only the
// publish path differs (see QuizStatus comment above).

model Quiz {
  id          String     @id @default(cuid())
  moduleId    String
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  kind        QuizKind   @default(QUIZ)
  title       String
  description String?
  timeLimitMinutes Int?
  maxAttempts      Int        @default(1)
  status           QuizStatus @default(DRAFT)

  // EXAM only: set by the lecturer to signal "ready for Examination Unit review",
  // without needing a dedicated enum value.
  submittedForSchedulingAt DateTime?

  // EXAM: set by Examination Unit via scheduleExam. QUIZ: left null (lecturer-published
  // quizzes are available as soon as status = PUBLISHED, no window needed).
  availableFrom  DateTime?
  availableUntil DateTime?
  scheduledById  String?
  scheduledBy    User?      @relation("QuizScheduledBy", fields: [scheduledById], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User     @relation("QuizCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([moduleId, status])
}

model QuizQuestion {
  id         String       @id @default(cuid())
  quizId     String
  quiz       Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type       QuestionType
  prompt     String       @db.Text
  points     Int          @default(1)
  orderIndex Int

  options QuizOption[]
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean      @default(false)
  orderIndex Int

  answers QuizAnswer[]

  @@index([questionId])
}

model QuizAttempt {
  id            String    @id @default(cuid())
  quizId        String
  quiz          Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId     String
  student       User      @relation("QuizAttemptStudent", fields: [studentId], references: [id])
  attemptNumber Int
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  // Populated together at submit time — auto-graded, no separate "gradedAt" step.
  pointsEarned  Int?
  totalPoints   Int?

  answers QuizAnswer[]

  @@unique([quizId, studentId, attemptNumber])
  @@index([quizId, studentId])
}

model QuizAnswer {
  id               String       @id @default(cuid())
  attemptId        String
  attempt          QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId       String
  question         QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  // MCQ / TRUE_FALSE
  selectedOptionId String?
  selectedOption   QuizOption?  @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)
  isCorrect        Boolean?
  // ESSAY — free-text response, manually graded by the lecturer afterwards
  textResponse     String?      @db.Text
  // Points actually awarded for this answer. Set immediately at submit time for
  // auto-graded MCQ/TRUE_FALSE; left null for ESSAY until a lecturer grades it.
  pointsAwarded    Int?

  @@unique([attemptId, questionId])
}

// ---------- ANNOUNCEMENTS ----------

model Announcement {
  id          String            @id @default(cuid())
  scope       AnnouncementScope
  title       String
  body        String            @db.Text
  isPinned    Boolean           @default(false)
  publishedAt DateTime          @default(now())

  moduleId String? // required (non-null) when scope = MODULE; validated in the action layer
  module   Module? @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, moduleId])
}

// ---------- DISCUSSION BOARDS ----------
// Flat thread + reply model (not a recursive comment tree) — matches "course-scoped
// Q&A space" scope. Lecturer and student have symmetric create/reply permissions;
// only the lecturer who owns the module can pin/lock/delete (see discussion.actions.ts).

model DiscussionThread {
  id       String  @id @default(cuid())
  moduleId String
  module   Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title    String
  body     String  @db.Text
  authorId String
  author   User    @relation(fields: [authorId], references: [id])
  isPinned Boolean @default(false)
  isLocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts DiscussionPost[]

  @@index([moduleId])
}

model DiscussionPost {
  id       String           @id @default(cuid())
  threadId String
  thread   DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId String
  author   User             @relation(fields: [authorId], references: [id])
  body     String           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId])
}

// ---------- REGISTRATION & PAYMENT ----------

model SemesterRegistration {
  id              String             @id @default(cuid())
  studentId       String
  student         User               @relation("StudentRegistrations", fields: [studentId], references: [id])
  semesterId      String
  semester        Semester           @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  // Curriculum year this registration is for (e.g. 1st year of the program) — together with
  // the student's program and the semester's number, this determines which modules are
  // auto-selected and which ProgramCurriculumFee applies.
  yearLevel       Int
  status          RegistrationStatus @default(PAYMENT_PENDING)
  submittedAt     DateTime?
  decidedAt       DateTime?
  decidedById     String?
  decidedBy       User?              @relation("DecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrationModules RegistrationModule[]
  paymentRecords      PaymentRecord[]

  @@unique([studentId, semesterId])
  @@index([status])
}

model RegistrationModule {
  id             String               @id @default(cuid())
  registrationId String
  registration   SemesterRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())

  @@unique([registrationId, moduleId])
}

model PaymentRecord {
  id                 String                    @id @default(cuid())
  registrationId     String
  registration       SemesterRegistration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  amount             Decimal                   @db.Decimal(10, 2)
  currency           String                    @default("LKR")
  method             PaymentMethod             @default(BANK_TRANSFER)
  // Bank transfer only: uploaded receipt. Null for gateway payments (the gateway record is the proof).
  receiptUrl         String?
  receiptFileName    String?
  // Gateway only: which provider processed it and its transaction reference.
  gatewayProvider    String?
  gatewayReference   String?
  uploadedAt         DateTime                  @default(now())
  verificationStatus PaymentVerificationStatus @default(PENDING)
  verifiedById       String?
  verifiedBy         User?                     @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt         DateTime?
  verificationNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([verificationStatus])
}

model Enrollment {
  id             String           @id @default(cuid())
  studentId      String
  student        User             @relation(fields: [studentId], references: [id])
  moduleId       String
  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  registrationId String? // audit link back to the approving registration
  status         EnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime         @default(now())

  @@unique([studentId, moduleId])
}

// ---------- CALENDAR ----------

model CalendarEvent {
  id             String            @id @default(cuid())
  title          String
  description    String?
  type           CalendarEventType
  startDate      DateTime
  endDate        DateTime?
  isAllDay       Boolean           @default(true)
  academicYearId String?
  semesterId     String?
  semester       Semester?         @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User              @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
}

// ---------- NOTIFICATION AUDIT ----------

model NotificationLog {
  id              String             @id @default(cuid())
  type            String // e.g. "REGISTRATION_APPROVED"
  recipientEmail  String
  recipientUserId String?
  subject         String
  status          NotificationStatus
  error           String?
  meta            Json?
  sentAt          DateTime           @default(now())
}
