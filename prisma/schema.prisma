// Prisma schema for CIMS Campus LMS — see plan doc for design rationale.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- ENUMS ----------

enum Role {
  SUPER_ADMIN
  CAMPUS_ADMIN
  ACADEMIC_DIRECTOR
  PROGRAM_COORDINATOR
  LECTURER
  FINANCE
  MARKETING_OFFICER
  EXAMINATION_UNIT
  LIBRARY_OFFICER
  HR_OFFICER
  STUDENT
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  VISITING
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScholarshipStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScholarshipDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DisciplineStatus {
  OPEN
  RESOLVED
}

enum DisciplineOutcome {
  NONE
  WARNING
  SUSPENSION
  EXPULSION
}

enum ContentType {
  FILE
  LINK
  VIDEO
  ZOOM
  GOOGLE_MEET
  RICH_TEXT
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum AnnouncementScope {
  INSTITUTION
  MODULE
}

enum DiscussionScope {
  INSTITUTION
  MODULE
}

enum ForumCategory {
  GENERAL
  ACADEMIC
  EVENTS
  CAREERS
  OTHER
}

enum RegistrationStatus {
  PAYMENT_PENDING
  PENDING
  APPROVED
  REJECTED
}

enum PaymentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentMethod {
  BANK_TRANSFER
  GATEWAY
}

enum SemesterStatus {
  UPCOMING
  ACTIVE
  CLOSED
}

enum CalendarEventType {
  SEMESTER_START
  SEMESTER_END
  EXAM_PERIOD
  HOLIDAY
  DEADLINE
  OTHER
}

enum EnrollmentStatus {
  ACTIVE
  WITHDRAWN
  COMPLETED
}

enum NotificationStatus {
  SENT
  FAILED
  STUBBED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum QuizKind {
  QUIZ
  EXAM
  PRACTICAL
}

// QUIZ: DRAFT -> PUBLISHED -> CLOSED (lecturer-controlled, like ContentStatus).
// EXAM: DRAFT -> SCHEDULED -> CLOSED (SCHEDULED only reachable via the Examination
// Unit's scheduleExam action; submittedForSchedulingAt marks a DRAFT exam as ready
// for their review queue).
// PRACTICAL: DRAFT -> PUBLISHED -> CLOSED, same self-publish path as QUIZ. Has zero
// QuizQuestion rows — scored via RubricCriterion/RubricScore instead, lecturer-graded
// directly with no student-facing attempt flow.
enum QuizStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  CLOSED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  ESSAY
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ---------- CORE ----------

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String? // null for OAuth-only accounts (e.g. Google sign-in)
  firstName    String
  lastName     String
  phone        String?
  role         Role
  isActive     Boolean @default(true)

  // Only meaningful for STUDENT role: assigned lazily on first transcript issuance, not at
  // admission — see ensureRegistrationNumber in transcript.actions.ts.
  registrationNumber String? @unique

  // Only meaningful for STUDENT role: home program for catalog default / dashboard.
  // SetNull rather than Cascade: deleting a Program should not delete student accounts.
  programId String?
  program   Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  // Only meaningful for non-STUDENT roles: employment/HR record, editable by HR_OFFICER via
  // updateStaffEmploymentDetails (deliberately a separate action from updateUser — identity/
  // role/password changes stay SUPER_ADMIN/CAMPUS_ADMIN-only, employment data is HR's).
  jobTitle        String?
  department      String?
  employmentType  EmploymentType?
  startDate       DateTime?
  contractEndDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lecturerAssignments       LecturerModuleAssignment[] @relation("LecturerAssignments")
  assignmentsGranted        LecturerModuleAssignment[] @relation("AssignedBy")
  registrations             SemesterRegistration[]     @relation("StudentRegistrations")
  decisionsGiven            SemesterRegistration[]     @relation("DecidedBy")
  enrollments               Enrollment[]
  announcementsAuthored     Announcement[]
  paymentsVerified          PaymentRecord[]            @relation("PaymentVerifiedBy")
  passwordResetTokens       PasswordResetToken[]
  calendarEventsCreated     CalendarEvent[]
  contentItemsCreated       ContentItem[]
  submissions               Submission[]               @relation("StudentSubmissions")
  submissionsGraded         Submission[]               @relation("SubmissionGradedBy")
  discussionThreadsAuthored DiscussionThread[]
  discussionPostsAuthored   DiscussionPost[]
  quizzesCreated            Quiz[]                     @relation("QuizCreatedBy")
  quizzesScheduled          Quiz[]                     @relation("QuizScheduledBy")
  quizAttempts              QuizAttempt[]              @relation("QuizAttemptStudent")
  notificationReads         NotificationRead[]
  certificatesEarned        Certificate[]              @relation("CertificateStudent")
  certificatesIssued        Certificate[]              @relation("CertificateIssuedBy")
  taughtSessions            ClassSession[]             @relation("ClassSessionLecturer")
  attendanceRecords         AttendanceRecord[]         @relation("AttendanceStudent")
  attendanceRecordsMarked   AttendanceRecord[]         @relation("AttendanceMarkedBy")
  applicationsReviewed      Application[]              @relation("ApplicationReviewedBy")
  applicationCreated        Application?               @relation("ApplicationCreatedUser")
  moduleGradeLocksApplied   ModuleGradeLock[]           @relation("ModuleGradeLockedBy")
  moduleGradeLocksRemoved   ModuleGradeLock[]           @relation("ModuleGradeUnlockedBy")
  invigilatedExams          Quiz[]                      @relation("QuizInvigilator")
  transcriptsEarned         Transcript[]                @relation("TranscriptStudent")
  transcriptsIssued         Transcript[]                @relation("TranscriptIssuedBy")
  leaveRequestsSubmitted    StaffLeaveRequest[]         @relation("StaffLeaveRequests")
  leaveRequestsDecided      StaffLeaveRequest[]         @relation("StaffLeaveDecidedBy")
  scholarshipsApplied       Scholarship[]               @relation("ScholarshipStudent")
  scholarshipsDecided       Scholarship[]               @relation("ScholarshipDecidedBy")
  disciplineCasesAsStudent  DisciplineCase[]             @relation("DisciplineCaseStudent")
  disciplineCasesReported   DisciplineCase[]             @relation("DisciplineCaseReportedBy")
  disciplineCasesResolved   DisciplineCase[]             @relation("DisciplineCaseResolvedBy")

  @@index([role])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ---------- ACADEMIC STRUCTURE ----------

model Program {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?
  durationYears Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  modules        Module[]
  students       User[]
  curriculumFees ProgramCurriculumFee[]
  applications   Application[]
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// A prospective student's public application — no User account exists until approved.
// referenceCode is a public opaque lookup key (same convention as Certificate.verificationCode)
// so an applicant can check their status without an account.
model Application {
  id              String            @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String?
  programId       String
  program         Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  statement       String?           @db.Text
  status          ApplicationStatus @default(PENDING)
  referenceCode   String            @unique
  submittedAt     DateTime          @default(now())
  reviewedById    String?
  reviewedBy      User?             @relation("ApplicationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  rejectionReason String?
  createdUserId   String?           @unique
  createdUser     User?             @relation("ApplicationCreatedUser", fields: [createdUserId], references: [id], onDelete: SetNull)
  offerLetterUrl  String?

  @@index([status])
  @@index([referenceCode])
}

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "2025/2026"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false) // only one should be active; enforced in academic-year.actions.ts
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  semesters Semester[]
  modules   Module[]
}

// A program's fee for a given curriculum position (e.g. "Year 1, Semester 1"). Keyed by
// yearLevel + semesterNumber rather than a specific Semester row, because the fee for
// "Year 1 Semester 1" is a property of the program's curriculum, not of any one academic
// year's calendar instance — it doesn't need re-entering every time a new academic year's
// Semester 1 is created, and it varies both across programs and across years of the same program.
model ProgramCurriculumFee {
  id             String   @id @default(cuid())
  programId      String
  program        Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  yearLevel      Int
  semesterNumber Int
  amount         Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([programId, yearLevel, semesterNumber])
}

model Semester {
  id                   String         @id @default(cuid())
  academicYearId       String
  academicYear         AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name                 String // "Semester 1"
  semesterNumber       Int // 1, 2 (or 3 for trimester systems)
  startDate            DateTime
  endDate              DateTime
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?
  // Fee lives on ProgramCurriculumFee (programId + yearLevel + semesterNumber), not here —
  // see that model's comment for why.
  status               SemesterStatus @default(UPCOMING)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  modules        Module[]
  registrations  SemesterRegistration[]
  calendarEvents CalendarEvent[]

  @@unique([academicYearId, semesterNumber])
}

model Module {
  id          String  @id @default(cuid())
  code        String // e.g. "CS101" — unique per offering, not globally
  title       String
  description String?
  credits     Int?
  yearLevel   Int // curriculum year of study within the program (1,2,3,4)
  capacity    Int?
  isActive    Boolean @default(true)

  programId      String
  program        Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  semesterId     String
  semester       Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weeks                ModuleWeek[]
  lecturerAssignments  LecturerModuleAssignment[]
  classSessions        ClassSession[]
  announcements        Announcement[]
  enrollments          Enrollment[]
  registrationModules  RegistrationModule[]
  discussionThreads    DiscussionThread[]
  quizzes              Quiz[]
  certificates         Certificate[]
  assessmentCategories AssessmentCategory[]
  learningOutcomes     LearningOutcome[]
  gradeLock            ModuleGradeLock?

  @@unique([code, academicYearId, semesterId])
  @@index([programId])
  @@index([academicYearId, semesterId])
}

model LecturerModuleAssignment {
  id           String   @id @default(cuid())
  lecturerId   String
  lecturer     User     @relation("LecturerAssignments", fields: [lecturerId], references: [id])
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  assignedById String?
  assignedBy   User?    @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  assignedAt   DateTime @default(now())

  @@unique([lecturerId, moduleId])
}

// ---------- CLASS SESSIONS / TIMETABLE ----------

// Recurring weekly class schedule for a module — day of week + clock time, not a fixed
// date, since it repeats every week for the module's semester. Double-booking (same room
// or same lecturer overlapping in time) is a range-overlap problem, not an equality one,
// so it can't be expressed as a DB @@unique constraint — it's checked explicitly in
// class-session.actions.ts before create/update, the same way AcademicYear.isActive's
// "only one active" invariant is enforced in application code rather than the schema.
model ClassSession {
  id        String    @id @default(cuid())
  moduleId  String
  module    Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  dayOfWeek DayOfWeek
  // "HH:MM", 24h zero-padded — lexicographic string comparison matches chronological
  // order, so Prisma lt/gt filters work directly for overlap queries with no date math.
  startTime String
  endTime   String
  room      String

  lecturerId String
  lecturer   User   @relation("ClassSessionLecturer", fields: [lecturerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendanceRecords AttendanceRecord[]

  @@index([dayOfWeek, room])
  @@index([dayOfWeek, lecturerId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// One row per student per real calendar-date occurrence of a recurring ClassSession — the
// session itself has no date, only a weekly dayOfWeek, so occurrenceDate is what pins this
// record to an actual class meeting. occurrenceDate is validated in the action layer to
// actually fall on the session's dayOfWeek; the schema doesn't enforce that (same division
// of concerns as ClassSession's own overlap-conflict check).
model AttendanceRecord {
  id             String           @id @default(cuid())
  classSessionId String
  classSession   ClassSession     @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  occurrenceDate DateTime
  studentId      String
  student        User             @relation("AttendanceStudent", fields: [studentId], references: [id])
  status         AttendanceStatus
  markedById     String
  markedBy       User             @relation("AttendanceMarkedBy", fields: [markedById], references: [id])
  markedAt       DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([classSessionId, occurrenceDate, studentId])
  @@index([studentId])
}

// ---------- WEEKLY CONTENT ----------

model ModuleWeek {
  id          String   @id @default(cuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  weekNumber  Int
  title       String? // e.g. "Week 1: Introduction"
  description String?
  orderIndex  Int // supports drag-reorder independent of weekNumber
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contentItems ContentItem[]

  @@unique([moduleId, weekNumber])
}

model ContentItem {
  id          String        @id @default(cuid())
  weekId      String
  week        ModuleWeek    @relation(fields: [weekId], references: [id], onDelete: Cascade)
  type        ContentType
  title       String
  description String?
  status      ContentStatus @default(DRAFT)
  orderIndex  Int
  publishedAt DateTime?

  // type-specific, nullable fields (single-table, pragmatic for Phase 1)
  fileUrl       String?
  fileName      String?
  fileSizeBytes Int?
  mimeType      String?
  linkUrl       String?
  videoUrl      String?
  zoomJoinUrl   String?
  zoomMeetingId String?
  zoomPasscode  String?
  meetJoinUrl   String?
  richTextHtml  String? @db.Text

  // Meaningful only for type ZOOM / GOOGLE_MEET — when the live session actually starts.
  // Required by the form for those two types, but stays nullable at the DB level so
  // content items created before this field existed don't need a backfill.
  scheduledAt DateTime?

  // assignment fields — dueDate/isAssignment orthogonal to type; grading lives on Submission
  isAssignment Boolean   @default(false)
  dueDate      DateTime?

  // Optional — an assignment with no category is excluded from the module's weighted
  // grade (shown informationally in the Grade Book), not an error.
  assessmentCategoryId String?
  assessmentCategory   AssessmentCategory? @relation(fields: [assessmentCategoryId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Submission[]

  @@index([weekId, status])
}

model Submission {
  id            String      @id @default(cuid())
  contentItemId String
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  studentId     String
  student       User        @relation("StudentSubmissions", fields: [studentId], references: [id])
  textResponse  String?     @db.Text
  fileUrl       String?
  submittedAt   DateTime    @default(now())
  grade         Decimal?    @db.Decimal(5, 2)
  feedback      String?
  gradedAt      DateTime?
  gradedById    String?
  gradedBy      User?       @relation("SubmissionGradedBy", fields: [gradedById], references: [id], onDelete: SetNull)
  updatedAt     DateTime    @updatedAt

  @@unique([contentItemId, studentId])
}

// ---------- ASSESSMENT (QUIZZES & EXAMS) ----------
// QUIZ: authored and published directly by the owning lecturer, like an assignment.
// EXAM: lecturer drafts the questions then submits for scheduling; an Examination Unit
// staff member sets the availability window and publishes it (scheduleExam). Both kinds
// share one model since the question/attempt/grading machinery is identical — only the
// publish path differs (see QuizStatus comment above).

model Quiz {
  id          String     @id @default(cuid())
  moduleId    String
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  kind        QuizKind   @default(QUIZ)
  title       String
  description String?
  timeLimitMinutes Int?
  maxAttempts      Int        @default(1)
  status           QuizStatus @default(DRAFT)

  // EXAM only: set by the lecturer to signal "ready for Examination Unit review",
  // without needing a dedicated enum value.
  submittedForSchedulingAt DateTime?

  // EXAM: set by Examination Unit via scheduleExam. QUIZ: left null (lecturer-published
  // quizzes are available as soon as status = PUBLISHED, no window needed).
  availableFrom  DateTime?
  availableUntil DateTime?
  scheduledById  String?
  scheduledBy    User?      @relation("QuizScheduledBy", fields: [scheduledById], references: [id], onDelete: SetNull)

  // EXAM only, set alongside availableFrom/availableUntil by scheduleExam. Conflict-checked
  // against other SCHEDULED exams for the same venue/invigilator (see checkExamConflict).
  venue         String?
  invigilatorId String?
  invigilator   User?   @relation("QuizInvigilator", fields: [invigilatorId], references: [id], onDelete: SetNull)

  // Optional — a quiz with no category is excluded from the module's weighted grade.
  assessmentCategoryId String?
  assessmentCategory   AssessmentCategory? @relation(fields: [assessmentCategoryId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User     @relation("QuizCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions        QuizQuestion[]
  attempts         QuizAttempt[]
  rubricCriteria   RubricCriterion[]
  learningOutcomes LearningOutcome[]

  @@index([moduleId, status])
  @@index([venue])
  @@index([invigilatorId])
}

model QuizQuestion {
  id         String       @id @default(cuid())
  quizId     String
  quiz       Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type       QuestionType
  prompt     String       @db.Text
  points     Int          @default(1)
  orderIndex Int

  options QuizOption[]
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean      @default(false)
  orderIndex Int

  answers QuizAnswer[]

  @@index([questionId])
}

model QuizAttempt {
  id            String    @id @default(cuid())
  quizId        String
  quiz          Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId     String
  student       User      @relation("QuizAttemptStudent", fields: [studentId], references: [id])
  attemptNumber Int
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  // Populated together at submit time — auto-graded, no separate "gradedAt" step.
  pointsEarned  Int?
  totalPoints   Int?
  // When the score/answer breakdown becomes visible to the student. Set immediately
  // at submit time for quizzes with no ESSAY questions (nothing left to grade). For
  // quizzes containing an ESSAY question, stays null until the lecturer explicitly
  // publishes via publishAttemptResults, once every essay answer has a pointsAwarded.
  resultsPublishedAt DateTime?

  answers      QuizAnswer[]
  rubricScores RubricScore[]

  @@unique([quizId, studentId, attemptNumber])
  @@index([quizId, studentId])
}

model QuizAnswer {
  id               String       @id @default(cuid())
  attemptId        String
  attempt          QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId       String
  question         QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  // MCQ / TRUE_FALSE
  selectedOptionId String?
  selectedOption   QuizOption?  @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)
  isCorrect        Boolean?
  // ESSAY — free-text response, manually graded by the lecturer afterwards
  textResponse     String?      @db.Text
  // Points actually awarded for this answer. Set immediately at submit time for
  // auto-graded MCQ/TRUE_FALSE; left null for ESSAY until a lecturer grades it.
  pointsAwarded    Int?

  @@unique([attemptId, questionId])
}

// A practical/hands-on assessment's scoring criteria (e.g. "Technique" /10, "Safety" /5).
// Only meaningful for Quiz.kind === PRACTICAL — a practical quiz has zero QuizQuestion rows;
// the whole attempt is scored against these criteria instead of individual questions.
model RubricCriterion {
  id         String   @id @default(cuid())
  quizId     String
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  name       String
  maxPoints  Int
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  scores RubricScore[]

  @@index([quizId])
}

model RubricScore {
  id            String          @id @default(cuid())
  criterionId   String
  criterion     RubricCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  attemptId     String
  attempt       QuizAttempt     @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  pointsAwarded Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([criterionId, attemptId])
}

model LearningOutcome {
  id          String   @id @default(cuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  code        String // e.g. "LO1"
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quizzes Quiz[] // implicit many-to-many — a quiz can align to several outcomes and vice versa

  @@unique([moduleId, code])
}

// One row per module, mutable toggle (not a full multi-cycle audit log — locking/unlocking a
// module's marks is expected to be rare, so tracking only the most recent lock/unlock action
// is a deliberate scope decision, not an oversight). Locked iff the row exists and
// unlockedAt is null.
model ModuleGradeLock {
  id           String    @id @default(cuid())
  moduleId     String    @unique
  module       Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lockedAt     DateTime  @default(now())
  lockedById   String
  lockedBy     User      @relation("ModuleGradeLockedBy", fields: [lockedById], references: [id])
  unlockedAt   DateTime?
  unlockedById String?
  unlockedBy   User?     @relation("ModuleGradeUnlockedBy", fields: [unlockedById], references: [id], onDelete: SetNull)
}

// A module's assessment weighting scheme (e.g. "Assignments" 40%, "Quizzes" 30%, "Final
// Exam" 30%). Weights summing to 100% across a module is enforced in the action layer, not
// here — an aggregate constraint across sibling rows can't be a single-row @@unique, same
// division of concerns as ClassSession's overlap check and AcademicYear.isActive. A content
// item / quiz with no category is simply excluded from the weighted grade calculation.
model AssessmentCategory {
  id            String   @id @default(cuid())
  moduleId      String
  module        Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  name          String
  weightPercent Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contentItems ContentItem[]
  quizzes      Quiz[]

  @@unique([moduleId, name])
  @@index([moduleId])
}

// ---------- ANNOUNCEMENTS ----------

model Announcement {
  id          String            @id @default(cuid())
  scope       AnnouncementScope
  title       String
  body        String            @db.Text
  isPinned    Boolean           @default(false)
  publishedAt DateTime          @default(now())

  moduleId String? // required (non-null) when scope = MODULE; validated in the action layer
  module   Module? @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, moduleId])
}

// ---------- DISCUSSION BOARDS ----------
// Flat thread + reply model (not a recursive comment tree) — matches "course-scoped
// Q&A space" scope. Lecturer and student have symmetric create/reply permissions;
// only the lecturer who owns the module can pin/lock/delete (see discussion.actions.ts).

model DiscussionThread {
  id       String          @id @default(cuid())
  scope    DiscussionScope @default(MODULE)
  moduleId String?
  module   Module?         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  category ForumCategory? // only meaningful when scope = INSTITUTION
  title    String
  body     String          @db.Text
  authorId String
  author   User            @relation(fields: [authorId], references: [id])
  isPinned Boolean         @default(false)
  isLocked Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts DiscussionPost[]

  @@index([moduleId])
  @@index([scope, category])
}

model DiscussionPost {
  id       String           @id @default(cuid())
  threadId String
  thread   DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId String
  author   User             @relation(fields: [authorId], references: [id])
  body     String           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId])
}

// ---------- REGISTRATION & PAYMENT ----------

model SemesterRegistration {
  id              String             @id @default(cuid())
  studentId       String
  student         User               @relation("StudentRegistrations", fields: [studentId], references: [id])
  semesterId      String
  semester        Semester           @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  // Curriculum year this registration is for (e.g. 1st year of the program) — together with
  // the student's program and the semester's number, this determines which modules are
  // auto-selected and which ProgramCurriculumFee applies.
  yearLevel       Int
  status          RegistrationStatus @default(PAYMENT_PENDING)
  submittedAt     DateTime?
  decidedAt       DateTime?
  decidedById     String?
  decidedBy       User?              @relation("DecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrationModules RegistrationModule[]
  paymentRecords      PaymentRecord[]

  @@unique([studentId, semesterId])
  @@index([status])
}

model RegistrationModule {
  id             String               @id @default(cuid())
  registrationId String
  registration   SemesterRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())

  @@unique([registrationId, moduleId])
}

model PaymentRecord {
  id                 String                    @id @default(cuid())
  registrationId     String
  registration       SemesterRegistration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  amount             Decimal                   @db.Decimal(10, 2)
  currency           String                    @default("LKR")
  method             PaymentMethod             @default(BANK_TRANSFER)
  // Bank transfer only: uploaded receipt. Null for gateway payments (the gateway record is the proof).
  receiptUrl         String?
  receiptFileName    String?
  // Gateway only: which provider processed it and its transaction reference.
  gatewayProvider    String?
  gatewayReference   String?
  uploadedAt         DateTime                  @default(now())
  verificationStatus PaymentVerificationStatus @default(PENDING)
  verifiedById       String?
  verifiedBy         User?                     @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt         DateTime?
  verificationNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice?

  @@index([verificationStatus])
}

// Generated automatically the moment a payment is verified — not user-initiated, so there's
// no create/edit form. One invoice per payment record.
model Invoice {
  id              String        @id @default(cuid())
  paymentRecordId String        @unique
  paymentRecord   PaymentRecord @relation(fields: [paymentRecordId], references: [id], onDelete: Cascade)
  invoiceNumber   String        @unique
  pdfUrl          String
  issuedAt        DateTime      @default(now())
}

model Enrollment {
  id             String           @id @default(cuid())
  studentId      String
  student        User             @relation(fields: [studentId], references: [id])
  moduleId       String
  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  registrationId String? // audit link back to the approving registration
  status         EnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime         @default(now())

  @@unique([studentId, moduleId])
}

// ---------- CERTIFICATES ----------
// Manually issued by Examination Unit staff (issueCertificate) — no auto-trigger off
// enrollment/module completion. Per-module, not per-program: Program has no direct
// AcademicYear/Semester of its own (only reachable via Module), so a whole-program
// certificate would need to aggregate across every module a student completed —
// deferred; add a Certificate.kind later if that's wanted.

model Certificate {
  id               String   @id @default(cuid())
  studentId        String
  student          User     @relation("CertificateStudent", fields: [studentId], references: [id])
  moduleId         String
  module           Module   @relation(fields: [moduleId], references: [id])
  verificationCode String   @unique
  fileUrl          String
  issuedById       String
  issuedBy         User     @relation("CertificateIssuedBy", fields: [issuedById], references: [id])
  issuedAt         DateTime @default(now())

  @@unique([studentId, moduleId])
  @@index([verificationCode])
}

// ---------- TRANSCRIPTS ----------
// Student-wide, GPA-based — distinct from Certificate (per-module). Not unique on studentId:
// a student's GPA changes each semester, so transcripts are reissuable point-in-time
// snapshots, not a one-time document.

model Transcript {
  id               String   @id @default(cuid())
  studentId        String
  student          User     @relation("TranscriptStudent", fields: [studentId], references: [id])
  verificationCode String   @unique
  cumulativeGpa    Decimal? @db.Decimal(3, 2)
  fileUrl          String
  issuedById       String
  issuedBy         User     @relation("TranscriptIssuedBy", fields: [issuedById], references: [id])
  issuedAt         DateTime @default(now())

  @@index([verificationCode])
  @@index([studentId])
}

// ---------- STAFF MANAGEMENT ----------

model StaffLeaveRequest {
  id           String      @id @default(cuid())
  staffId      String
  staff        User        @relation("StaffLeaveRequests", fields: [staffId], references: [id])
  type         LeaveType
  startDate    DateTime
  endDate      DateTime
  reason       String      @db.Text
  status       LeaveStatus @default(PENDING)
  decidedById  String?
  decidedBy    User?       @relation("StaffLeaveDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime    @default(now())

  @@index([staffId, status])
}

// ---------- SCHOLARSHIPS ----------
// Student applies with a reason only; Finance decides both approval and the discount at
// decision time (discountType/discountValue stay null until approved) — the student doesn't
// propose their own discount. getEffectiveFee (src/lib/fees.ts) picks the single
// most-recently-approved row per student; no stacking multiple approved scholarships, no
// per-semester expiry.

model Scholarship {
  id            String                   @id @default(cuid())
  studentId     String
  student       User                     @relation("ScholarshipStudent", fields: [studentId], references: [id])
  reason        String                   @db.Text
  status        ScholarshipStatus        @default(PENDING)
  discountType  ScholarshipDiscountType?
  discountValue Decimal?                 @db.Decimal(10, 2)
  decidedById   String?
  decidedBy     User?                    @relation("ScholarshipDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  decidedAt     DateTime?
  decisionNote  String?
  createdAt     DateTime                 @default(now())

  @@index([studentId, status])
}

// ---------- DISCIPLINE ----------
// Coordinator files (maker), Academic Director resolves (checker) — same maker/decider shape
// as StaffLeaveRequest above. Staff-only: no student-facing view of these records.

model DisciplineCase {
  id             String            @id @default(cuid())
  studentId      String
  student        User              @relation("DisciplineCaseStudent", fields: [studentId], references: [id])
  reportedById   String
  reportedBy     User              @relation("DisciplineCaseReportedBy", fields: [reportedById], references: [id])
  incidentDate   DateTime
  description    String            @db.Text
  status         DisciplineStatus  @default(OPEN)
  outcome        DisciplineOutcome @default(NONE)
  resolvedById   String?
  resolvedBy     User?             @relation("DisciplineCaseResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime          @default(now())

  @@index([studentId, status])
}

// ---------- CALENDAR ----------

model CalendarEvent {
  id             String            @id @default(cuid())
  title          String
  description    String?
  type           CalendarEventType
  startDate      DateTime
  endDate        DateTime?
  isAllDay       Boolean           @default(true)
  academicYearId String?
  semesterId     String?
  semester       Semester?         @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User              @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
}

// ---------- NOTIFICATION AUDIT ----------

model NotificationLog {
  id              String              @id @default(cuid())
  type            String // e.g. "REGISTRATION_APPROVED"
  channel         NotificationChannel @default(EMAIL)
  recipient       String // email address or phone number, depending on channel
  recipientUserId String?
  subject         String? // meaningful for EMAIL only; null for SMS/WhatsApp
  body            String? @db.Text // the actual message content sent, for audit
  status          NotificationStatus
  error           String?
  meta            Json?
  sentAt          DateTime            @default(now())

  @@index([recipientUserId])
  @@index([channel, sentAt])
}

// Per-item read state for the in-app notification bell (student-feed.ts). `key`
// matches the synthesized id of a NotificationItem (e.g. "quiz-<attemptId>") — a
// row's presence means that specific notification has been opened, not a "checked
// up to this timestamp" cutoff, so unread state survives per-item across sessions.
model NotificationRead {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key    String
  readAt DateTime @default(now())

  @@unique([userId, key])
}
