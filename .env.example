# Local dev database managed by `npx prisma dev` (see prisma.config.ts). Swap for a real
# managed Postgres (Neon/Supabase/RDS) connection string for staging/production.
DATABASE_URL="postgresql://user:password@localhost:5432/cims_campus?schema=public"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"

# File storage (Cloudinary) — leave blank in dev to no-op; fill in to enable real uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
STORAGE_PROVIDER="cloudinary"

# Email (Resend) — leave RESEND_API_KEY blank to use the console/dev notification adapter
RESEND_API_KEY=""
EMAIL_FROM="CIMS Campus <no-reply@cims.edu>"
